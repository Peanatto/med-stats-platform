// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// CORE AUTHENTICATION
// ==========================================

model User {
  id                   String   @id @default(uuid()) @db.Uuid
  email                String   @unique @db.VarChar(255)
  passwordHash         String?  @map("password_hash") @db.VarChar(255)
  authProvider         String   @default("email") @map("auth_provider") @db.VarChar(20)
  role                 String   @default("student") @db.VarChar(20)
  isVerifiedMedStudent Boolean  @default(false) @map("is_verified_med_student")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  profile              Profile?
  serviceListings      ServiceListing[] @relation("ProviderListings")
  bookingsAsClient     Booking[]        @relation("ClientBookings")
  bookingsAsProvider   Booking[]        @relation("ProviderBookings")
  reviewsWritten       Review[]         @relation("ReviewerReviews")

  @@map("users")
}

// ==========================================
// USER PROFILES
// ==========================================

model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  displayName     String   @unique @map("display_name") @db.VarChar(50)
  profileType     String   @default("premed") @map("profile_type") @db.VarChar(20)
  undergradMajor  String   @map("undergrad_major") @db.VarChar(100)
  
  cumulativeGpa   Decimal? @map("cumulative_gpa") @db.Decimal(3, 2)
  scienceGpa      Decimal? @map("science_gpa") @db.Decimal(3, 2)
  mcatScore       Int?     @map("mcat_score")
  
  clinicalHours   Int      @default(0) @map("clinical_hours")
  researchHours   Int      @default(0) @map("research_hours")
  shadowingHours  Int      @default(0) @map("shadowing_hours")
  volunteerHours  Int      @default(0) @map("volunteer_hours")
  
  adviceSnippet   String?  @map("advice_snippet") @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relation definition
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ==========================================
// THE SHARING ECONOMY
// ==========================================

model ServiceListing {
  id           String   @id @default(uuid()) @db.Uuid
  providerId   String   @map("provider_id") @db.Uuid
  title        String   @db.VarChar(255)
  description  String   @db.Text
  category     String   @db.VarChar(50)
  hourlyRate   Decimal  @default(0.00) @map("hourly_rate") @db.Decimal(6, 2)
  tags         String[] 
  isActive     Boolean  @default(true) @map("is_active")
  
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  provider     User      @relation("ProviderListings", fields: [providerId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  reviews      Review[]

  @@map("service_listings")
}

model Booking {
  id            String   @id @default(uuid()) @db.Uuid
  listingId     String   @map("listing_id") @db.Uuid
  clientId      String   @map("client_id") @db.Uuid
  providerId    String   @map("provider_id") @db.Uuid
  
  topic         String   @db.VarChar(100)
  duration      Decimal  @db.Decimal(4, 2)
  totalCost     Decimal  @map("total_cost") @db.Decimal(6, 2)
  
  dateTime      DateTime @map("date_time") @db.Timestamptz
  notes         String?  @db.Text
  
  status        String   @default("pending") @db.VarChar(20)
  
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  listing       ServiceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  client        User           @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  provider      User           @relation("ProviderBookings", fields: [providerId], references: [id], onDelete: Cascade)
  review        Review?

  @@map("bookings")
}

model Review {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String   @unique @map("booking_id") @db.Uuid
  listingId   String   @map("listing_id") @db.Uuid
  reviewerId  String   @map("reviewer_id") @db.Uuid
  rating      Int      @db.SmallInt
  comment     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listing     ServiceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer    User           @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@map("reviews")
}